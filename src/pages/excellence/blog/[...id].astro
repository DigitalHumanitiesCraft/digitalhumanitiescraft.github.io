---
import { getCollection } from 'astro:content';
import BlogPost from '../../../components/excellence/BlogPost.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => data.published);
  return posts.map((post) => ({ params: { id: post.id }, props: { post } }));
}

const { post } = Astro.props;
// Deutsche Chrome-Variante. Die andere Sprachvariante liegt unter /en/…; der Artikeltext
// selbst kann eine andere Sprache haben (contentLang wird in BlogPost separat behandelt).
const path = `/excellence/blog/${post.id}/`;
const altPath = `/en/excellence/blog/${post.id}/`;
---

<BlogPost post={post} lang="de" path={path} altPath={altPath} />
