---
import Base from '../../layouts/Base.astro';
import Nav from '../Nav.astro';
import Footer from '../Footer.astro';
import type { Lang } from '../../i18n/content';
import { getBlogContent } from '../../i18n/blog';
import { getChannelVideos } from '../../lib/videos';

interface Props {
  lang: Lang;
  path: string;
  altPath: string;
}

const { lang, path, altPath } = Astro.props;
const { t, posts } = getBlogContent(lang);
const homeHref = lang === 'de' ? '/' : '/en/';

// Artikel zuerst, Videos als eigener Abschnitt darunter (Experte, 2026-07-08); je absteigend nach Datum
const sortedPosts = [...posts].sort((a, b) => b.date.localeCompare(a.date));
const videos = (await getChannelVideos()).sort((a, b) => b.published.localeCompare(a.published));
const isExternal = (u: string) => /^https?:/.test(u);

const fmtDate = (iso: string) => {
  const [y, m, d] = iso.slice(0, 10).split('-');
  return `${d}.${m}.${y}`;
};
---

<Base lang={lang} title={t.metaTitle} description={t.metaDescription} path={path} altPath={altPath}>
  <a href="#main" class="skip-link">{t.skipLink}</a>
  <div class="page">
    <Nav lang={lang} altPath={altPath} homeHref={homeHref} />
    <main id="main">
      <section class="head-section">
        <div class="wash" aria-hidden="true"></div>
        <div class="wrap head">
          <div class="kicker">{t.kicker}</div>
          <h1>{t.title}</h1>
          <a href="#videos" class="jump">{t.jumpVideos}</a>
        </div>
      </section>
      <section class="posts">
        <div class="wrap">
          <h2 class="section-label">{t.sectionPosts}</h2>
          <div class="grid">
            {
              sortedPosts.map((p) => (
                <a href={p.url} class="card post-card" target={isExternal(p.url) ? '_blank' : undefined} rel={isExternal(p.url) ? 'noopener' : undefined}>
                  <div class="banner">
                    {p.thumb ? <img src={p.thumb} alt="" loading="lazy" class="thumb" /> : null}
                    <div class="hex banner-hex" aria-hidden="true" />
                  </div>
                  <div class="body">
                    <span class="date">{fmtDate(p.date)}</span>
                    <h3>{p.title}</h3>
                  </div>
                </a>
              ))
            }
          </div>
        </div>
      </section>
      <section class="videos" id="videos">
        <div class="wrap">
          <h2 class="section-label">{t.sectionVideos}</h2>
          <div class="grid">
            {
              videos.map((v) => (
                <a href={`https://www.youtube.com/watch?v=${v.id}`} target="_blank" rel="noopener" class="card video-card">
                  <div class="thumb-wrap">
                    <img src={`https://i.ytimg.com/vi/${v.id}/mqdefault.jpg`} alt="" loading="lazy" />
                    <div class="play" aria-hidden="true">
                      <span class="play-btn">
                        <svg viewBox="0 0 24 24" fill="#fff"><path d="M8 5v14l11-7z" /></svg>
                      </span>
                    </div>
                  </div>
                  <div class="body">
                    <span class="date">{fmtDate(v.published)}</span>
                    <h3>{v.title}</h3>
                  </div>
                </a>
              ))
            }
          </div>
        </div>
      </section>
    </main>
    <Footer lang={lang} />
  </div>
</Base>

<style>
  .page {
    min-height: 100vh;
    overflow: clip;
  }

  .head-section {
    position: relative;
  }

  .wash {
    position: absolute;
    inset: -120px -300px 0 -300px;
    pointer-events: none;
    background: radial-gradient(ellipse 560px 400px at 85% 25%, rgba(138, 79, 163, 0.1), transparent 68%);
    filter: blur(30px);
  }

  .head {
    position: relative;
    padding-block: 72px 40px;
    max-width: 1200px;
  }

  .kicker {
    color: var(--purple);
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(36px, 4.3vw, 52px);
    line-height: 1.08;
    letter-spacing: -0.03em;
    font-weight: 800;
    margin: 0 0 18px;
  }

  .jump {
    display: inline-block;
    font-weight: 600;
    font-size: 14.5px;
    color: var(--purple);
    border-bottom: 2px solid rgba(138, 79, 163, 0.3);
    padding-bottom: 2px;
  }

  .jump:hover {
    color: var(--ink);
    border-color: var(--ink);
  }

  .section-label {
    font-family: var(--font-display);
    font-size: 24px;
    font-weight: 700;
    letter-spacing: -0.01em;
    margin: 0 0 28px;
  }

  .posts {
    padding-block: 16px 40px;
  }

  .videos {
    padding-block: 40px 96px;
    scroll-margin-top: 90px;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .card {
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(30, 39, 73, 0.09);
    border-radius: 16px;
    background: var(--paper);
    overflow: hidden;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }

  .card:hover {
    border-color: rgba(138, 79, 163, 0.3);
    box-shadow: 0 16px 40px rgba(30, 39, 73, 0.1);
  }

  .banner {
    height: 150px;
    position: relative;
    overflow: hidden;
    background: var(--paper);
  }

  .banner .thumb {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
  }

  .banner-hex {
    position: absolute;
    right: 22px;
    bottom: -15px;
    width: 28px;
    height: 31px;
    background: var(--ink);
  }

  .body {
    padding: 20px 24px 24px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .date {
    font-size: 12.5px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(30, 39, 73, 0.45);
  }

  h3 {
    font-family: var(--font-display);
    font-size: 17px;
    font-weight: 600;
    line-height: 1.4;
    letter-spacing: -0.01em;
    margin: 0;
  }

  .thumb-wrap {
    position: relative;
    aspect-ratio: 16 / 9;
    background: var(--ink-deep);
  }

  .thumb-wrap img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .play {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .play-btn {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: rgba(22, 29, 56, 0.82);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .play-btn svg {
    width: 20px;
    height: 20px;
    margin-left: 3px;
  }

  @media (max-width: 1000px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 700px) {
    .grid {
      grid-template-columns: 1fr;
    }

    h1 {
      font-size: 34px;
    }
  }
</style>
