---
import { render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Nav from '../Nav.astro';
import Footer from '../Footer.astro';

import type { Lang } from '../../i18n/content';

interface Props {
  post: CollectionEntry<'blog'>;
  /** UI-/Chrome-Sprache dieser Seite (aus der Route, NICHT aus der Artikelsprache). */
  lang: Lang;
  /** Pfad dieser Sprachvariante, z. B. "/excellence/blog/<id>/" bzw. "/en/excellence/blog/<id>/". */
  path: string;
  /** Pfad derselben Seite in der anderen Sprache (für den Sprachumschalter und hreflang). */
  altPath: string;
}

const { post, lang, path, altPath } = Astro.props;
const { Content, headings } = await render(post);
const d = post.data;

// Sprache des Werks (Artikeltext) — unabhängig von der Chrome-Sprache. Ein englischer
// Essay bleibt englisch, auch wenn die Seite mit deutschem Chrome aufgerufen wird.
const contentLang = d.citation?.language ?? 'de';
const site = Astro.site?.href.replace(/\/$/, '') ?? 'https://dhcraft.org';
const url = `${site}${path}`;
const author = d.author;
const rights = d.dublin_core?.rights ?? 'CC BY 4.0';
const description = d.dublin_core?.description ?? d.citation?.abstract ?? '';
const abstract = d.citation?.abstract;
const subjects = d.dublin_core?.subject ?? [];
const blogPath = lang === 'de' ? '/excellence/blog/' : '/en/excellence/blog/';
// Quelltext liegt seit der Migration im Home-Repo (src/content/blog/), nicht mehr im alten excellence-Repo.
const markdownUrl = `https://raw.githubusercontent.com/DigitalHumanitiesCraft/digitalhumanitiescraft.github.io/refs/heads/main/src/content/blog/${post.id}.md`;
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);
// Der Fußnoten-Label kommt aus der Markdown-Pipeline englisch; im TOC in der
// Inhaltssprache anzeigen (das rehype-Plugin lokalisiert die Überschrift selbst).
const footnoteLabel = contentLang === 'en' ? 'Footnotes' : 'Fußnoten';

const dateDisplay = d.date.toLocaleDateString('de-AT', { day: '2-digit', month: '2-digit', year: 'numeric' });
// APA-Datum wie im Altsystem: "2026, February 09"
const apaDate = `${d.date.getFullYear()}, ${d.date.toLocaleDateString('en-US', { month: 'long' })} ${String(d.date.getDate()).padStart(2, '0')}`;
// Autor:innen-Feld kann mehrere Namen als "First Last, First Last, …" enthalten.
const authorNames = author.split(',').map((n) => n.trim()).filter(Boolean);
// Ein Name "First … Last" → "Last, F." (Initialen aller Vornamen).
const apaName = (name: string) => {
  const parts = name.split(/\s+/);
  const last = parts.at(-1);
  const initials = parts.slice(0, -1).map((p) => `${p[0].toUpperCase()}.`).join(' ');
  return initials ? `${last}, ${initials}` : last;
};
// APA-Autor:innenliste: 1 Name; 2 mit "& "; ab 3 mit ", & " vor dem letzten.
const apaAuthors =
  authorNames.length <= 1
    ? apaName(author)
    : `${authorNames.slice(0, -1).map(apaName).join(', ')}, & ${apaName(authorNames.at(-1)!)}`;
const apaCitation = `${apaAuthors} (${apaDate}). ${d.title}. Digital Humanities Craft. ${url}`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': d.schema_type,
  headline: d.title,
  author: authorNames.length > 1 ? authorNames.map((name) => ({ '@type': 'Person', name })) : { '@type': 'Person', name: author },
  datePublished: d.date.toISOString(),
  dateModified: (d.last_modified_at ?? d.date).toISOString(),
  description: description.slice(0, 160),
  ...(abstract ? { abstract } : {}),
  url,
  mainEntityOfPage: { '@type': 'WebPage', '@id': url },
  publisher: { '@type': 'Organization', name: 'Digital Humanities Craft', url: site },
  ...(d.keywords ? { keywords: d.keywords } : {}),
  inLanguage: contentLang,
  license: rights,
};

// COinS für Zotero (Parität zum alten Post-Layout)
const coins = new URLSearchParams({
  ctx_ver: 'Z39.88-2004',
  rft_val_fmt: 'info:ofi/fmt:kev:mtx:dc',
  rfr_id: 'info:sid/dhcraft.org:generator',
  'rft.type': 'blogPost',
  'rft.title': d.title,
  'rft.creator': author,
  'rft.publisher': 'Digital Humanities Craft',
  'rft.source': 'Digital Humanities Craft',
  'rft.date': d.date.toISOString().slice(0, 10),
  'rft.identifier': url,
  'rft.language': contentLang,
  'rft.rights': rights,
}).toString();

const ui =
  lang === 'de'
    ? {
        toc: 'Inhalt',
        abstract: 'Abstract',
        keywords: 'Schlagwörter',
        author: 'Autor',
        published: 'Veröffentlicht',
        license: 'Lizenz',
        back: '← Zurück zur Blogübersicht',
        print: 'Als PDF drucken',
        markdown: 'Markdown',
        citationTitle: 'Zitiervorschlag (APA)',
        copy: 'Zitiervorschlag kopieren',
        copied: 'Kopiert! ✓',
        skipLink: 'Zum Inhalt springen',
      }
    : {
        toc: 'Contents',
        abstract: 'Abstract',
        keywords: 'Keywords',
        author: 'Author',
        published: 'Published',
        license: 'License',
        back: '← Back to blog overview',
        print: 'Print as PDF',
        markdown: 'Markdown',
        citationTitle: 'Suggested citation (APA)',
        copy: 'Copy citation',
        copied: 'Copied! ✓',
        skipLink: 'Skip to content',
      };
---

<Base lang={lang} title={`${d.title} | Digital Humanities Craft`} description={description.slice(0, 160)} path={path} altPath={altPath} ogType="article">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <meta name="DC.title" content={d.title} />
    <meta name="DC.creator" content={d.dublin_core?.creator ?? author} />
    <meta name="DC.date" content={d.date.toISOString()} />
    <meta name="DC.publisher" content={d.dublin_core?.publisher ?? 'Digital Humanities Craft'} />
    {description && <meta name="DC.description" content={description} />}
    <meta name="DC.language" content={contentLang} />
    <meta name="DC.type" content={d.dublin_core?.type ?? 'Blogpost'} />
    <meta name="DC.format" content="text/html" />
    <meta name="DC.rights" content={rights} />
    <meta name="DC.identifier" content={url} />
    {subjects.map((s) => <meta name="DC.subject" content={s} />)}
    <meta name="citation_title" content={d.title} />
    {authorNames.map((name) => <meta name="citation_author" content={name} />)}
    <meta name="citation_publication_date" content={d.date.toISOString().slice(0, 10).replaceAll('-', '/')} />
    <meta name="citation_journal_title" content="Digital Humanities Craft" />
    <meta name="citation_publisher" content="Digital Humanities Craft" />
    <meta name="citation_abstract_html_url" content={url} />
    <meta name="citation_fulltext_html_url" content={url} />
    <meta name="citation_language" content={contentLang} />
    {abstract && <meta name="citation_abstract" content={abstract} />}
  </Fragment>

  <a href="#main" class="skip-link">{ui.skipLink}</a>
  <div class="page">
    <Nav lang={lang} altPath={altPath} homeHref={lang === 'de' ? '/' : '/en/'} />
    <main id="main">
      <div class="wrap layout">
        {
          toc.length > 0 && (
            <aside class="toc-sidebar" aria-label={ui.toc}>
              <nav class="toc">
                <span class="toc-label">{ui.toc}</span>
                <a href="#top" class="toc-link toc-top">
                  {d.short_title ?? d.title}
                </a>
                {toc.map((h) => (
                  <a href={`#${h.slug}`} class:list={['toc-link', { sub: h.depth === 3 }]}>
                    {h.slug === 'footnote-label' ? footnoteLabel : h.text}
                  </a>
                ))}
              </nav>
            </aside>
          )
        }
        <article class="post" id="top" lang={contentLang}>
          <span class="Z3988" title={coins} aria-hidden="true"></span>
          <header class="post-header">
            <h1>{d.title}</h1>
            {
              abstract && (
                <div class="abstract">
                  <strong>{ui.abstract}:</strong> {abstract}
                </div>
              )
            }
            {
              d.keywords && (
                <p class="keywords">
                  <strong>{ui.keywords}:</strong> {d.keywords.join(', ')}
                </p>
              )
            }
            <div class="meta">
              <span><strong>{ui.author}:</strong> {author}</span>
              <span class="sep" aria-hidden="true">•</span>
              <span><strong>{ui.published}:</strong> {dateDisplay}</span>
              <span class="sep" aria-hidden="true">•</span>
              <span><strong>{ui.license}:</strong> {rights}</span>
            </div>
            <div class="actions">
              <a href={blogPath} class="btn btn-outline action">{ui.back}</a>
              <button type="button" class="btn btn-outline action" onclick="window.print()">{ui.print}</button>
              <a href={markdownUrl} target="_blank" rel="noopener" class="btn btn-outline action">{ui.markdown} ↗</a>
            </div>
          </header>

          <div class="content">
            <Content />
          </div>

          <footer class="citation">
            <h2>{ui.citationTitle}</h2>
            <p class="citation-text" id="citation-apa">
              {apaAuthors} ({apaDate}). {d.title}. <em>Digital Humanities Craft</em>. {url}
            </p>
            <button type="button" class="btn btn-outline action" id="copy-citation" data-copied={ui.copied}>{ui.copy}</button>
          </footer>
        </article>
      </div>
    </main>
    <Footer lang={lang} />
  </div>
</Base>

<script is:inline>
  document.getElementById('copy-citation')?.addEventListener('click', function () {
    const btn = this;
    const text = document.getElementById('citation-apa').innerText;
    navigator.clipboard.writeText(text).then(() => {
      const original = btn.textContent;
      btn.textContent = btn.dataset.copied;
      setTimeout(() => {
        btn.textContent = original;
      }, 2000);
    });
  });
</script>

<style>
  .page {
    min-height: 100vh;
    overflow: clip;
  }

  .layout {
    display: grid;
    grid-template-columns: 240px minmax(0, 720px);
    gap: 56px;
    justify-content: center;
    padding-block: 64px 96px;
  }

  .toc-sidebar {
    position: sticky;
    top: 90px;
    align-self: start;
    max-height: calc(100vh - 110px);
    overflow-y: auto;
  }

  .toc {
    display: flex;
    flex-direction: column;
    gap: 8px;
    border-left: 2px solid rgba(30, 39, 73, 0.08);
    padding-left: 16px;
  }

  .toc-label {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(30, 39, 73, 0.5);
    margin-bottom: 4px;
  }

  .toc-link {
    font-size: 13.5px;
    line-height: 1.4;
    color: rgba(30, 39, 73, 0.7);
  }

  .toc-link:hover {
    color: var(--purple);
  }

  .toc-top {
    font-weight: 600;
    color: var(--ink);
  }

  .toc-link.sub {
    padding-left: 14px;
    font-size: 13px;
  }

  .post-header h1 {
    font-family: var(--font-display);
    font-size: clamp(28px, 3.2vw, 40px);
    line-height: 1.15;
    letter-spacing: -0.02em;
    font-weight: 700;
    margin: 0 0 20px;
  }

  .abstract {
    background: #fff;
    border: 1px solid rgba(30, 39, 73, 0.09);
    border-left: 3px solid var(--purple);
    border-radius: 12px;
    padding: 18px 20px;
    font-size: 15px;
    line-height: 1.65;
    color: rgba(30, 39, 73, 0.8);
    margin: 0 0 16px;
  }

  .keywords {
    font-size: 14px;
    line-height: 1.6;
    color: rgba(30, 39, 73, 0.65);
    margin: 0 0 16px;
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    font-size: 14px;
    color: rgba(30, 39, 73, 0.7);
    margin-bottom: 20px;
  }

  .sep {
    color: rgba(30, 39, 73, 0.3);
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    padding-bottom: 28px;
    border-bottom: 1px solid rgba(30, 39, 73, 0.08);
  }

  .action {
    padding: 8px 16px;
    font-size: 13.5px;
    font-weight: 600;
    cursor: pointer;
    background: transparent;
    font-family: inherit;
    color: inherit;
  }

  .content {
    padding-top: 28px;
    font-size: 16px;
    line-height: 1.7;
  }

  .content :global(h2) {
    font-family: var(--font-display);
    font-size: 26px;
    line-height: 1.2;
    letter-spacing: -0.01em;
    font-weight: 700;
    margin: 44px 0 16px;
  }

  .content :global(h3) {
    font-family: var(--font-display);
    font-size: 20px;
    line-height: 1.3;
    font-weight: 600;
    margin: 32px 0 12px;
  }

  .content :global(p) {
    margin: 0 0 16px;
  }

  .content :global(a) {
    color: var(--purple);
    font-weight: 500;
    text-decoration: underline;
    text-decoration-color: rgba(138, 79, 163, 0.35);
    text-underline-offset: 3px;
  }

  .content :global(a:hover) {
    color: var(--pink);
  }

  .content :global(img),
  .content :global(video) {
    max-width: 100%;
    height: auto;
    border-radius: 12px;
    border: 1px solid rgba(30, 39, 73, 0.09);
    /* Großzügiger Abstand nach unten; bei Bildern MIT Caption zieht die
       Caption sich per negativem oberen Rand wieder dicht ans Bild. */
    margin: 20px 0 24px;
  }

  /* Bildunterschrift: kleiner, gedämpft, zentriert, direkt unter dem Bild */
  .content :global(.image-caption) {
    display: block;
    margin: -20px 0 28px;
    font-size: 13.5px;
    line-height: 1.5;
    color: rgba(30, 39, 73, 0.6);
    text-align: center;
    font-style: italic;
  }

  .content :global(.image-caption a) {
    color: rgba(30, 39, 73, 0.6);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .content :global(blockquote) {
    border-left: 3px solid var(--lime);
    margin: 20px 0;
    padding: 4px 0 4px 20px;
    color: rgba(30, 39, 73, 0.75);
    font-style: italic;
  }

  .content :global(code) {
    background: rgba(30, 39, 73, 0.06);
    border-radius: 6px;
    padding: 2px 6px;
    font-size: 0.9em;
  }

  .content :global(pre) {
    background: var(--ink-deep);
    color: #f5f5f0;
    border-radius: 12px;
    padding: 18px 20px;
    overflow-x: auto;
    font-size: 14px;
    line-height: 1.6;
  }

  .content :global(pre code) {
    background: none;
    padding: 0;
    font-size: inherit;
  }

  .content :global(ul),
  .content :global(ol) {
    margin: 0 0 16px;
    padding-left: 26px;
  }

  .content :global(li) {
    margin-bottom: 6px;
  }

  .content :global(table) {
    border-collapse: collapse;
    width: 100%;
    margin: 20px 0;
    font-size: 14.5px;
    display: block;
    overflow-x: auto;
  }

  .content :global(th),
  .content :global(td) {
    border: 1px solid rgba(30, 39, 73, 0.12);
    padding: 8px 12px;
    text-align: left;
  }

  .content :global(th) {
    background: rgba(30, 39, 73, 0.04);
    font-weight: 600;
  }

  .content :global(hr) {
    border: none;
    border-top: 1px solid rgba(30, 39, 73, 0.1);
    margin: 36px 0;
  }

  .citation {
    margin-top: 48px;
    background: #fff;
    border: 1px solid rgba(30, 39, 73, 0.09);
    border-radius: 16px;
    padding: 24px 28px;
  }

  .citation h2 {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 600;
    margin: 0 0 12px;
  }

  .citation-text {
    font-size: 14.5px;
    line-height: 1.65;
    color: rgba(30, 39, 73, 0.8);
    margin: 0 0 16px;
    word-break: break-word;
  }

  @media (max-width: 1000px) {
    .layout {
      grid-template-columns: minmax(0, 720px);
    }

    .toc-sidebar {
      display: none;
    }
  }

  /* ================================================================
     PDF-/Druckausgabe im Journal-Stil (zweispaltig, Serifenschrift,
     Blocksatz, vollbreite Abbildungen). Ziel: LaTeX-artiges Offprint.
     ================================================================ */
  @media print {
    @page {
      size: A4;
      margin: 17mm 15mm 18mm;
    }

    :global(html),
    :global(body) {
      background: #fff !important;
    }

    :global(.nav),
    :global(.footer),
    .toc-sidebar,
    .actions,
    .citation button,
    :global(.to-top),
    :global(.skip-link) {
      display: none !important;
    }

    .page {
      overflow: visible;
    }

    .layout {
      display: block;
      padding: 0;
      max-width: none;
    }

    /* Serifen-Grundschrift des ganzen Beitrags */
    .post {
      font-family: 'Iowan Old Style', 'Palatino Linotype', 'Book Antiqua', Palatino, Georgia, 'Times New Roman', serif;
      color: #000;
    }

    /* --- Masthead: Journal-Name, Titel, Autor:innen, Abstract (vollbreit) --- */
    .post-header {
      text-align: center;
      border-bottom: 1.1pt solid #000;
      padding-bottom: 11pt;
      margin-bottom: 15pt;
    }

    .post-header::before {
      content: 'Digital Humanities Craft';
      display: block;
      font-variant: small-caps;
      letter-spacing: 0.14em;
      font-size: 8.5pt;
      color: #000;
      padding-bottom: 9pt;
      margin-bottom: 11pt;
      border-bottom: 0.4pt solid #777;
    }

    .post-header h1 {
      font-family: inherit;
      font-size: 20pt;
      line-height: 1.15;
      letter-spacing: 0;
      font-weight: 700;
      margin: 0 0 9pt;
    }

    .abstract {
      background: none;
      border: none;
      border-radius: 0;
      max-width: 84%;
      margin: 11pt auto 7pt;
      padding: 0;
      font-size: 8.7pt;
      line-height: 1.5;
      color: #000;
      text-align: justify;
      hyphens: auto;
      -webkit-hyphens: auto;
    }

    .abstract strong {
      font-variant: small-caps;
      letter-spacing: 0.05em;
    }

    .keywords {
      max-width: 84%;
      margin: 0 auto;
      font-size: 8.4pt;
      color: #000;
      text-align: center;
    }

    .meta {
      justify-content: center;
      gap: 6pt;
      font-size: 8.4pt;
      color: #000;
      margin: 9pt 0 0;
    }

    .meta .sep {
      color: #000;
    }

    /* --- Zweispaltiger Fließtext im Blocksatz --- */
    .content {
      column-count: 2;
      column-gap: 7mm;
      padding-top: 0;
      font-size: 9.4pt;
      line-height: 1.48;
      text-align: justify;
      hyphens: auto;
      -webkit-hyphens: auto;
      orphans: 3;
      widows: 3;
    }

    .content :global(p) {
      margin: 0;
      text-indent: 1.1em;
    }

    /* Erster Absatz und Absätze direkt nach Überschriften ohne Einzug (LaTeX-Konvention) */
    .content :global(p:first-child),
    .content :global(h2 + p),
    .content :global(h3 + p),
    .content :global(figure + p),
    .content :global(pre + p),
    .content :global(table + p),
    .content :global(blockquote + p) {
      text-indent: 0;
    }

    .content :global(h2) {
      font-family: inherit;
      font-size: 11pt;
      font-weight: 700;
      letter-spacing: 0;
      margin: 12pt 0 4pt;
      break-after: avoid;
    }

    .content :global(h3) {
      font-family: inherit;
      font-size: 9.8pt;
      font-weight: 700;
      font-style: italic;
      margin: 9pt 0 3pt;
      break-after: avoid;
    }

    /* Vollbreite Elemente überspannen beide Spalten und werden nicht getrennt */
    .content :global(figure),
    .content :global(img),
    .content :global(video),
    .content :global(table),
    .content :global(pre),
    .content :global(.image-caption),
    .content :global(figcaption) {
      column-span: all;
      break-inside: avoid;
    }

    /* Abbildungen wie im Journal proportionieren: moderate Höhe, zentriert.
       Quadratische/hochformatige Bilder würden bei voller Textbreite sonst
       fast seitenhoch. Höhendeckel greift zuerst, Breite skaliert mit. */
    .content :global(img),
    .content :global(video) {
      display: block;
      max-width: 100%;
      max-height: 88mm;
      width: auto;
      height: auto;
      margin: 8pt auto 15pt;
      border-radius: 0;
    }

    .content :global(.image-caption),
    .content :global(figcaption) {
      text-align: center;
      font-size: 8pt;
      font-style: italic;
      color: #333;
      /* negativer oberer Rand hebt den vergrößerten Bild-Unterrand auf,
         damit die Caption dicht unter dem Bild sitzt; Bilder OHNE Caption
         behalten den großzügigen Abstand zum folgenden Fließtext. */
      margin: -12pt 0 12pt;
    }

    .content :global(pre) {
      background: #fff;
      color: #000;
      border: 0.5pt solid #999;
      font-size: 7.8pt;
      line-height: 1.35;
      white-space: pre-wrap;
      word-wrap: break-word;
      padding: 6pt 8pt;
      margin: 9pt 0;
      border-radius: 0;
    }

    .content :global(code) {
      background: none;
      font-size: 0.92em;
    }

    .content :global(table) {
      width: 100%;
      border-collapse: collapse;
      font-size: 8.2pt;
      margin: 9pt 0;
    }

    .content :global(th),
    .content :global(td) {
      border: 0.5pt solid #999;
      padding: 3pt 5pt;
    }

    .content :global(th) {
      background: #ededed;
    }

    .content :global(blockquote) {
      border-left: 1.5pt solid #999;
      padding-left: 8pt;
      margin: 8pt 0;
      font-style: italic;
      color: #222;
      break-inside: avoid;
    }

    .content :global(ul),
    .content :global(ol) {
      margin: 4pt 0;
      padding-left: 1.3em;
    }

    .content :global(li) {
      margin: 1pt 0;
    }

    /* Fußnoten/Referenzblock (rehype) kleiner und vollbreit */
    .content :global(.footnotes) {
      column-span: all;
      border-top: 0.5pt solid #999;
      margin-top: 12pt;
      padding-top: 5pt;
      font-size: 8pt;
      line-height: 1.4;
    }

    .content :global(sup) {
      font-size: 0.72em;
    }

