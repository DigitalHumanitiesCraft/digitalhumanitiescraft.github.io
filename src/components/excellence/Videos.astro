---
import type { Lang } from '../../i18n/content';
import { getExcellenceContent } from '../../i18n/excellence';
import { getChannelVideos } from '../../lib/videos';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const { t } = getExcellenceContent(lang);
const all = (await getChannelVideos()).sort((a, b) => b.published.localeCompare(a.published));
const lead = all.slice(0, 3);
// „Alle Videos" führt zum Videos-Abschnitt der Blog-Übersicht (analog „Alle Beiträge")
const allVideosUrl = lang === 'de' ? '/excellence/blog/#videos' : '/en/excellence/blog/#videos';

const fmtDate = (iso: string) => {
  const [y, m, d] = iso.slice(0, 10).split('-');
  return `${d}.${m}.${y}`;
};
---

<section id="videos" class="videos">
  <div class="wrap">
    <div class="head">
      <div class="titles">
        <div class="kicker">{t.videosKicker}</div>
        <h2>{t.videosTitle}</h2>
      </div>
      <a href="https://www.youtube.com/@DigitalHumanitiesCraft" target="_blank" rel="noopener" class="channel">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23 7.5s-.2-1.6-.9-2.3c-.9-.9-1.9-.9-2.3-1C16.6 4 12 4 12 4s-4.6 0-7.8.2c-.4.1-1.4.1-2.3 1C1.2 5.9 1 7.5 1 7.5S.8 9.4.8 11.3v1.7c0 1.9.2 3.8.2 3.8s.2 1.6.9 2.3c.9.9 2 .9 2.5 1 1.8.2 7.6.2 7.6.2s4.6 0 7.8-.2c.4-.1 1.4-.1 2.3-1 .7-.7.9-2.3.9-2.3s.2-1.9.2-3.8v-1.7c0-1.9-.2-3.8-.2-3.8zM9.8 15.3V8.7l6.2 3.3-6.2 3.3z"></path></svg>
        @DigitalHumanitiesCraft
      </a>
    </div>
    <div class="grid">
      {
        lead.map((v) => (
          <a href={`https://www.youtube.com/watch?v=${v.id}`} target="_blank" rel="noopener" class="card">
            <div class="thumb">
              <img src={`https://i.ytimg.com/vi/${v.id}/mqdefault.jpg`} alt="" loading="lazy" />
              <span class="play" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="#fff"><path d="M8 5v14l11-7z" /></svg>
              </span>
            </div>
            <div class="meta">
              <span class="date">{fmtDate(v.published)}</span>
              <h3>{v.title}</h3>
            </div>
          </a>
        ))
      }
    </div>
    <div class="more">
      <a href={allVideosUrl} class="btn btn-outline">{t.videosAll} →</a>
    </div>
  </div>
</section>

<style>
  .videos {
    padding-block: 96px;
    background: #fff;
    border-top: 1px solid rgba(30, 39, 73, 0.06);
  }

  .head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 56px;
    flex-wrap: wrap;
  }

  .titles {
    max-width: 640px;
  }

  .kicker {
    color: var(--purple);
  }

  h2 {
    font-family: var(--font-display);
    font-size: 40px;
    line-height: 1.12;
    letter-spacing: -0.02em;
    font-weight: 700;
    margin: 0;
  }

  .channel {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--ink);
    color: #fff;
    padding: 12px 22px;
    border-radius: 999px;
    font-weight: 600;
    font-size: 14.5px;
    white-space: nowrap;
    transition: background 0.15s ease;
  }

  .channel:hover {
    background: var(--purple);
    color: #fff;
  }

  .channel svg {
    width: 18px;
    height: 18px;
  }

  .head > div:first-child {
    order: 0;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .more {
    margin-top: 40px;
    text-align: center;
  }

  .more .btn {
    padding: 13px 28px;
    font-size: 15px;
  }

  .card {
    display: flex;
    flex-direction: column;
    background: var(--paper);
    border: 1px solid rgba(30, 39, 73, 0.09);
    border-radius: 16px;
    overflow: hidden;
    transition: box-shadow 0.15s ease, border-color 0.15s ease;
  }

  .card:hover {
    box-shadow: 0 16px 40px rgba(30, 39, 73, 0.1);
    border-color: rgba(138, 79, 163, 0.3);
  }

  .thumb {
    position: relative;
    aspect-ratio: 16 / 9;
    background: var(--ink-deep);
  }

  .thumb img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .play {
    position: absolute;
    inset: 0;
    margin: auto;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: rgba(22, 29, 56, 0.82);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .play svg {
    width: 20px;
    height: 20px;
    margin-left: 3px;
  }

  .meta {
    padding: 20px 24px 24px;
  }

  .date {
    font-size: 12.5px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(30, 39, 73, 0.45);
  }

  h3 {
    font-family: var(--font-display);
    font-size: 17px;
    font-weight: 600;
    line-height: 1.4;
    margin: 6px 0 0;
  }

  @media (max-width: 900px) {
    .grid {
      grid-template-columns: 1fr;
    }

    h2 {
      font-size: 32px;
    }
  }
</style>
