---
import type { Lang } from '../../i18n/content';
import { getExcellenceContent } from '../../i18n/excellence';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const { t, updates } = getExcellenceContent(lang);

const fmtDate = (iso: string) => {
  const [y, m, d] = iso.split('-');
  return `${d}.${m}.${y}`;
};
---

<section id="updates" class="updates">
  <div class="wrap grid">
    <div class="intro">
      <div class="kicker">{t.updatesKicker}</div>
      <h2>{t.updatesTitle}</h2>
      <a href="https://patreon.com/DigitalHumanitiesCraft" target="_blank" rel="noopener" class="btn btn-solid cta">{t.updatesCta}</a>
    </div>
    <div class="feed">
      {
        updates.map((u) => (
          <article class="update">
            <div class="date">
              <span class="hex dot" aria-hidden="true" />
              {fmtDate(u.date)}
            </div>
            <p class="text">{u.text}</p>
            <a href={u.url} target="_blank" rel="noopener" class="link-card">
              <span class="link-title">{u.linkTitle}</span>
              <span class="link-source">{u.source}</span>
            </a>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .updates {
    padding-block: 96px;
  }

  .grid {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: 64px;
    align-items: start;
  }

  .intro {
    position: sticky;
    top: 96px;
  }

  .kicker {
    color: var(--purple);
  }

  h2 {
    font-family: var(--font-display);
    font-size: 40px;
    line-height: 1.12;
    letter-spacing: -0.02em;
    font-weight: 700;
    margin: 0 0 24px;
  }

  .cta {
    padding: 12px 24px;
    font-size: 14.5px;
  }

  .feed {
    display: flex;
    flex-direction: column;
  }

  .update {
    padding: 22px 0;
    border-bottom: 1px solid rgba(30, 39, 73, 0.07);
  }

  .update:first-child {
    padding-top: 0;
  }

  .update:last-child {
    border-bottom: none;
  }

  .date {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    font-weight: 600;
    color: rgba(30, 39, 73, 0.5);
    margin-bottom: 8px;
  }

  .dot {
    width: 11px;
    height: 12px;
    background: linear-gradient(135deg, var(--pink), var(--purple));
    display: inline-block;
  }

  .text {
    font-size: 15.5px;
    line-height: 1.6;
    margin: 0 0 12px;
  }

  .link-card {
    display: inline-flex;
    flex-direction: column;
    gap: 2px;
    max-width: 100%;
    border: 1px solid rgba(30, 39, 73, 0.12);
    border-radius: 12px;
    padding: 12px 16px;
    background: var(--paper);
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }

  .link-card:hover {
    border-color: rgba(138, 79, 163, 0.45);
    box-shadow: 0 8px 24px rgba(30, 39, 73, 0.07);
  }

  .link-title {
    font-family: var(--font-display);
    font-size: 14.5px;
    font-weight: 600;
    line-height: 1.4;
  }

  .link-source {
    font-size: 12.5px;
    color: rgba(30, 39, 73, 0.5);
  }

  @media (max-width: 900px) {
    .grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .intro {
      position: static;
    }

    h2 {
      font-size: 32px;
    }
  }
</style>
