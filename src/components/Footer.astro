---
import type { Lang } from '../i18n/content';
import { getContent } from '../i18n/content';
import logoWhite from '../assets/dhcraft_logo_invert_white.svg';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const { t } = getContent(lang);
// KI-Position vorerst ausgeblendet (2026-07-10), Seite selbst bleibt erreichbar
// const kiPositionPath = lang === 'de' ? '/ki-position/' : '/en/ki-position/';
const blogPath = lang === 'de' ? '/excellence/blog/' : '/en/excellence/blog/';
const pressPath = lang === 'de' ? '/press/' : '/en/press/';
// Anker auf die Startseite qualifizieren, damit sie auch von Unterseiten (z. B. Blog) funktionieren
const home = lang === 'de' ? '/' : '/en/';
---

<footer class="footer">
  <div class="wrap">
    <div class="cols">
      <div class="brand">
        <img src={logoWhite.src} alt="DHCraft" width="44" height="44" />
        <p>Digital Humanities Craft OG<br />research software · nerdy stuff · data workflows</p>
      </div>
      <div class="groups">
        <div class="group">
          <span class="label">{t.footerCompany}</span>
          <a href={`${home}#services`}>{t.navServices}</a>
          <a href={`${home}#projects`}>{t.navProjects}</a>
          <a href={`${home}#excellence`}>{t.navWebinars}</a>
          <a href={`${home}#team`}>Team</a>
          <a href={blogPath}>Blog</a>
          <a href={pressPath}>{t.footerPress}</a>
        </div>
        <div class="group">
          <span class="label">Social</span>
          <a href="https://www.linkedin.com/company/dhcraft" target="_blank" rel="noopener">LinkedIn</a>
          <a href="https://github.com/DigitalHumanitiesCraft" target="_blank" rel="noopener">GitHub</a>
          <a href="https://bsky.app/profile/dhcraft.bsky.social" target="_blank" rel="noopener">Bluesky</a>
          <a href="https://patreon.com/DigitalHumanitiesCraft" target="_blank" rel="noopener">Patreon</a>
        </div>
        <div class="group">
          <span class="label">{t.footerLegal}</span>
          <a href={lang === 'de' ? '/imprint/' : '/en/imprint/'}>{t.footerImprint}</a>
          {/* <a href={kiPositionPath}>{t.footerAi}</a> */}
          <a href="mailto:office@dhcraft.org">{t.navContact}</a>
        </div>
      </div>
    </div>
    <div class="bar">
      <span>© 2026 Digital Humanities Craft OG</span>
      <span>dhcraft.org</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--ink-deep);
    color: rgba(255, 255, 255, 0.75);
    padding: 56px 0 40px;
  }

  .cols {
    display: flex;
    gap: 48px;
    flex-wrap: wrap;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 44px;
  }

  .brand {
    max-width: 320px;
  }

  .brand img {
    height: 44px;
    width: auto;
    margin-bottom: 16px;
    display: block;
  }

  .brand p {
    font-size: 14px;
    line-height: 1.6;
    margin: 0;
  }

  .groups {
    display: flex;
    gap: 64px;
    flex-wrap: wrap;
  }

  .group {
    display: flex;
    flex-direction: column;
    gap: 10px;
    font-size: 14px;
  }

  .label {
    font-family: var(--font-display);
    font-weight: 600;
    color: #fff;
    font-size: 13px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 4px;
  }

  .group a {
    color: rgba(255, 255, 255, 0.7);
  }

  .group a:hover {
    color: var(--lime);
  }

  .bar {
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    padding-top: 24px;
    display: flex;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    font-size: 13.5px;
    color: rgba(255, 255, 255, 0.5);
  }
</style>
