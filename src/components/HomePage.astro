---
import Base from '../layouts/Base.astro';
import Nav from './Nav.astro';
import Hero from './Hero.astro';
import Services from './Services.astro';
import Projects from './Projects.astro';
import Partners from './Partners.astro';
import Team from './Team.astro';
import Formats from './excellence/Formats.astro';
import Videos from './excellence/Videos.astro';
import ChannelUpdates from './excellence/ChannelUpdates.astro';
import BlogTeasers from './BlogTeasers.astro';
import Contact from './Contact.astro';
import Footer from './Footer.astro';
import type { Lang } from '../i18n/content';
import { getContent } from '../i18n/content';

interface Props {
  lang: Lang;
  path: string;
  altPath: string;
}

const { lang, path, altPath } = Astro.props;
const { t } = getContent(lang);
---

<Base lang={lang} title={t.metaTitle} description={t.metaDescription} path={path} altPath={altPath}>
  <a href="#main" class="skip-link">{t.skipLink}</a>
  <div class="page">
    <Nav lang={lang} altPath={altPath} />
    <main id="main">
      <Hero lang={lang} />
      <Services lang={lang} />
      <Projects lang={lang} />
      <Partners lang={lang} />
      <Team lang={lang} />
      <Formats lang={lang} />
      <BlogTeasers lang={lang} />
      <Videos lang={lang} />
      <ChannelUpdates lang={lang} />
      <Contact lang={lang} />
    </main>
    <Footer lang={lang} />
  </div>
</Base>

<style>
  .page {
    min-height: 100vh;
    overflow: clip;
  }
</style>
