---
import { Image } from 'astro:assets';
import type { Lang } from '../i18n/content';
import { getContent } from '../i18n/content';
import watercolor from '../assets/dhcraft_logo_watercolor_transparent.png';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const { t } = getContent(lang);
---

<section id="contact" class="contact">
  <div class="wash" aria-hidden="true"></div>
  <div class="wrap inner">
    <Image src={watercolor} alt="" width={192} densities={[1, 2]} class="mark" />
    <h2>{t.contactTitle}</h2>
    <p class="sub">{t.contactSub}</p>
    <a href="mailto:office@dhcraft.org" class="btn btn-solid">{t.contactCta}</a>
    <p class="addr">office@dhcraft.org · Graz, Österreich</p>
  </div>
</section>

<style>
  .contact {
    position: relative;
    padding-block: 110px;
    overflow: hidden;
  }

  .wash {
    position: absolute;
    inset: -80px;
    pointer-events: none;
    background: radial-gradient(ellipse 560px 400px at 50% 40%, rgba(138, 79, 163, 0.12), transparent 68%);
    filter: blur(32px);
  }

  .inner {
    position: relative;
    max-width: 760px;
    text-align: center;
  }

  .mark {
    width: 96px;
    height: auto;
    margin: 0 auto 28px;
    display: block;
  }

  h2 {
    font-family: var(--font-display);
    font-size: clamp(32px, 4vw, 46px);
    line-height: 1.12;
    letter-spacing: -0.02em;
    font-weight: 700;
    margin: 0 0 18px;
  }

  .sub {
    font-size: 17.5px;
    line-height: 1.6;
    color: rgba(30, 39, 73, 0.72);
    margin: 0 0 36px;
  }

  .btn {
    padding: 16px 36px;
    font-size: 17px;
  }

  .addr {
    margin: 18px 0 0;
    font-size: 14.5px;
    color: rgba(30, 39, 73, 0.55);
  }
</style>
