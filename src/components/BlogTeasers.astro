---
import type { Lang } from '../i18n/content';
import { getContent } from '../i18n/content';
import { getBlogContent } from '../i18n/blog';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const { t } = getContent(lang);
const blogUrl = lang === 'de' ? '/excellence/blog/' : '/en/excellence/blog/';

// Nur die 3 neuesten Artikel als Teaser (Videos haben ihre eigene Sektion); Rest über den Button
const { posts } = getBlogContent(lang);
const teaserPosts = [...posts].sort((a, b) => b.date.localeCompare(a.date)).slice(0, 3);
const isExternal = (u: string) => /^https?:/.test(u);
---

<section id="blog" class="blog">
  <div class="wrap">
    <div class="head">
      <div class="kicker">Blog</div>
      <h2>{t.blogTitle}</h2>
    </div>
    <div class="grid">
      {
        teaserPosts.map((b) => (
          <a href={b.url} class="card" target={isExternal(b.url) ? '_blank' : undefined} rel={isExternal(b.url) ? 'noopener' : undefined}>
            <div class="banner">
              {b.thumb ? <img src={b.thumb} alt="" loading="lazy" class="thumb" /> : null}
              <div class="hex banner-hex" aria-hidden="true" />
            </div>
            <div class="body">
              <h3>{b.title}</h3>
            </div>
          </a>
        ))
      }
    </div>
    <div class="more">
      <a href={blogUrl} class="btn btn-outline">{t.blogAll} →</a>
    </div>
  </div>
</section>

<style>
  .blog {
    padding-block: 96px;
    background: #fff;
    border-top: 1px solid rgba(30, 39, 73, 0.06);
    border-bottom: 1px solid rgba(30, 39, 73, 0.06);
  }

  .head {
    max-width: 640px;
    margin-bottom: 56px;
  }

  .kicker {
    color: var(--purple);
  }

  h2 {
    font-family: var(--font-display);
    font-size: 40px;
    line-height: 1.12;
    letter-spacing: -0.02em;
    font-weight: 700;
    margin: 0;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .card {
    display: flex;
    flex-direction: column;
    background: var(--paper);
    border: 1px solid rgba(30, 39, 73, 0.09);
    border-radius: 16px;
    overflow: hidden;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }

  .card:hover {
    box-shadow: 0 16px 40px rgba(30, 39, 73, 0.1);
    border-color: rgba(138, 79, 163, 0.3);
  }

  .banner {
    height: 150px;
    position: relative;
    overflow: hidden;
    background: var(--paper);
  }

  .thumb {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
  }

  .banner-hex {
    position: absolute;
    right: 22px;
    bottom: -15px;
    width: 28px;
    height: 31px;
    background: var(--ink);
  }

  .body {
    padding: 22px 26px 26px;
    flex: 1;
  }

  h3 {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 600;
    line-height: 1.35;
    letter-spacing: -0.01em;
    margin: 0;
  }

  .more {
    margin-top: 40px;
    text-align: center;
  }

  .more .btn {
    padding: 13px 28px;
    font-size: 15px;
  }

  @media (max-width: 900px) {
    .grid {
      grid-template-columns: 1fr;
    }

    h2 {
      font-size: 32px;
    }
  }
</style>
